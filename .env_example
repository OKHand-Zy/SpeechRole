# Copy this file to .env and fill in your own keys.

# Required for HF/eval/openai_realtime_runner.py
OPENAI_API_KEY=

# Required for HF/eval/gemini_live_runner.py
# Either GEMINI_API_KEY or GOOGLE_API_KEY works.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional defaults used by the eval scripts when you pass explicit CLI flags.
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Required for HF/gemini_judge.py.
# gemini_judge.py uses the OpenAI SDK against an OpenAI-compatible Gemini endpoint.
GEMINI_JUDGE_API_KEY=
GEMINI_JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_JUDGE_MODEL=gemini-2.5-pro

# Optional: use comma-separated keys for quota rotation.
# GEMINI_JUDGE_API_KEYS=key_1,key_2,key_3
